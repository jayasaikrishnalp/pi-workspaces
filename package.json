{
  "name": "pi-workspace-server",
  "version": "0.1.0",
  "description": "Web workspace wrapping the pi agent CLI for WK CloudOps SREs.",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "start": "tsx src/server.ts",
    "test:smoke": "node --import tsx --test --test-concurrency=1 tests/*.smoke.mjs",
    "test:unit": "node --import tsx --test --test-concurrency=1 tests/*.test.mjs",
    "test:integration": "node --import tsx --test --test-concurrency=1 tests/integration/*.smoke.mjs",
    "test": "node --import tsx --test --test-concurrency=1 tests/*.test.mjs tests/*.smoke.mjs",
    "test:all": "node --import tsx --test --test-concurrency=1 tests/*.test.mjs tests/*.smoke.mjs tests/integration/*.smoke.mjs"
  },
  "author": "WK CloudOps Hackathon",
  "license": "UNLICENSED",
  "type": "module",
  "engines": {
    "node": ">=22.0.0"
  },
  "private": true,
  "devDependencies": {
    "@types/node": "22.10.5",
    "@types/sanitize-html": "^2.16.1",
    "tsx": "4.19.4",
    "typescript": "5.6.3"
  },
  "dependencies": {
    "chokidar": "^4.0.3",
    "sanitize-html": "^2.17.3"
  }
}
