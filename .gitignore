# dependencies
node_modules/

# build artifacts
dist/

# environment / secrets
.env
.env.local

# runtime state (workspace-specific)
.pi-workspace/
# Note: rooted patterns so the gitignore for runtime run-store doesn't also
# swallow the openspec/specs/runs/ source-of-truth spec.
/runs/
**/.pi-workspace-it-*/

# logs
*.log

# editor
.DS_Store
.vscode/
.idea/

# local-only artifacts (review bundles, scratch snapshots)
review/

# WK pipeline knowledge base — content-only, lives outside git
pipeline-information/

# Frontend build artifacts
web/node_modules/
web/dist/

# web/ build artifacts and Playwright outputs
web/dist/
web/test-results/
web/playwright-report/
web/playwright/.cache/
